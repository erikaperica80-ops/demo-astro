---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTenantConfig } from '../../lib/tenant';
import { resolveTemplate } from '../../lib/renderer';

const { tenant } = Astro.params;

if (!tenant) {
  return Astro.redirect('/');
}

const config = getTenantConfig(tenant);

if (!config) {
  return new Response(null, { status: 404, statusText: 'Tenant not found' });
}

const Template = await resolveTemplate(config.templateKey);

if (!Template) {
  return new Response(null, { status: 404, statusText: 'Template not found' });
}
---

<BaseLayout
  title={config.seo.title}
  description={config.seo.description}
  canonical={config.seo.canonical}
  robots={config.seo.robots}
  og={{ title: config.seo.title, description: config.seo.description }}
  twitter={{ card: 'summary_large_image', title: config.seo.title, description: config.seo.description }}
  theme={config.theme}
>
  <Template content={config.content} theme={config.theme} />
</BaseLayout>
