---
export interface Props {
  fields: any[];
}

const { fields } = Astro.props;

const getField = (id: string) =>
  fields?.find((f: any) => f.id === id && f.active !== false);

const heading = getField('heading')?.value ?? 'Ready to Get Started?';
const subheading = getField('subheading')?.value ?? '';
const buttonLabel = getField('button_label')?.value ?? 'Contact Us';
const buttonUrl = getField('button_url')?.value ?? '#';
---

<section
  class="py-24 bg-gradient-to-br from-[var(--color-primary,#2563eb)] to-[var(--color-secondary,#1e40af)]"
  id="cta"
>
  <div class="max-w-3xl mx-auto px-6 text-center text-white">
    <h2 class="text-3xl md:text-5xl font-extrabold mb-6 leading-tight">
      {heading}
    </h2>
    {
      subheading && (
        <p class="text-lg md:text-xl text-white/80 mb-10 leading-relaxed">{subheading}</p>
      )
    }
    <a
      href={buttonUrl as string}
      class="inline-block bg-[var(--color-accent,#f59e0b)] hover:opacity-90 transition-opacity text-gray-900 font-bold text-lg px-12 py-4 rounded-full shadow-2xl"
    >
      {buttonLabel}
    </a>
  </div>
</section>
